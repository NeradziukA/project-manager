# ══════════════════════════════════════════════════
#  .env — скопируй в .env и заполни все значения
# ══════════════════════════════════════════════════

# ── Telegram ───────────────────────────────────────
# Токен от @BotFather
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN

# Твой Telegram ID (узнать у @userinfobot). Через запятую если несколько.
ALLOWED_USER_IDS=123456789

# URL куда Telegram будет слать webhook (нужен HTTPS домен)
WEBHOOK_URL=https://YOUR_DOMAIN/webhook

# ── Redis ──────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# Имя менеджера и проекты (для оркестратора). Проекты через запятую.
MANAGER_NAME=hives-manager
MANAGER_PROJECTS=hives,nodejs

# Ключи Redis (уникальны для каждого менеджера если несколько на одном Redis)
TASK_QUEUE=claude:tasks:hives
RESULT_KEY=claude:last_result:hives
FAILED_QUEUE=claude:failed:hives

# ── Репозиторий ────────────────────────────────────
# Полный путь к папке с проектом на VPS
REPO_DIR=/opt/myproject

# ── pm2 ────────────────────────────────────────────
# Имя процесса pm2 (npx pm2 restart <имя>)
PM2_APP_NAME=hives

# ── Таймауты ───────────────────────────────────────
# Макс. секунд для выполнения задачи Claude Code
CLAUDE_TIMEOUT=300

# ── Порт бота ──────────────────────────────────────
PORT=8000
